{
  "$comment": "codetiger design system — machine-readable mirror of tokens.css. Identity: deep-navy cinematic console derived from the single-page résumé. Modernized: colours are OKLCH (perceptual, P3-ready); each themed colour carries `dark` + `light` (ink) branches that tokens.css unifies via light-dark(); `derived` means tokens.css computes it from a seed with relative-colour syntax (oklch(from …)). Keys are the exact CSS custom-property names. Run `node design-system/check-tokens.mjs` after editing to keep this file in sync (name reconciliation; not wired into any build).",
  "color": {
    "surfaces": {
      "--color-bg":          { "dark": "oklch(13.77% 0.0157 253.54)", "light": "oklch(100% 0 89.88)",      "hex": "#05090f / #ffffff", "use": "page base — near-black navy / white" },
      "--color-bg-elevated": { "dark": "oklch(22.74% 0.0386 254.05)", "light": "oklch(97.72% 0.0068 247.89)", "hex": "#0f1d2e / #f4f8fc", "use": "default surface: card / panel" },
      "--color-surface-2":   { "dark": "oklch(18.53% 0.0300 257.55)", "light": "oklch(96.18% 0.0086 247.91)", "hex": "#0a1320 / #eef3f8", "use": "nested cards, table head" },
      "--color-bg-inset":    { "dark": "oklch(12.00% 0.0153 252.51)", "light": "oklch(97.72% 0.0068 247.89)", "hex": "#03060b / #f4f8fc", "use": "recessed wells, code, inputs" }
    },
    "accent": {
      "--color-accent":       { "dark": "oklch(85.54% 0.0923 227.66)", "light": "oklch(52.15% 0.1363 247.86)", "hex": "#8cdcff / #0a6db3", "use": "cyan seed — the contract" },
      "--color-accent-2":     { "dark": "oklch(88.03% 0.1348 86.06)",  "light": "oklch(56.22% 0.1171 78.34)",  "hex": "#ffd166 / #9a6b00", "use": "gold — dates, external links" },
      "--color-accent-3":     { "dark": "oklch(89.30% 0.1290 165.92)", "light": "oklch(51.57% 0.1030 166.11)", "hex": "#7ef7c8 / #0f7a5a", "use": "mint — pills, success" },
      "--color-accent-hover": { "dark": "oklch(91.33% 0.0591 222.26)", "light": "oklch(43.26% 0.1086 246.35)", "hex": "#b8ecff / #075488", "use": "lighter/darker accent on hover" },
      "--accent-cyan-vivid":  { "value": "oklch(78.56% 0.1479 224.27)", "hex": "#00ccff", "use": "high-energy cyan for emissive states (dark-only)" }
    },
    "border": {
      "--color-border":        { "dark": "derived: oklch(from var(--color-accent) l c h / 0.16)", "light": "oklch(89.29% 0.0175 248.02)", "hex": "light #d3dde7", "use": "default hairline (cyan tint dark, neutral grey ink)" },
      "--color-border-muted":  { "dark": "derived: oklch(from var(--color-accent) l c h / 0.08)", "light": "oklch(93.65% 0.0111 243.66)", "hex": "light #e4ebf1", "use": "subtle divider" },
      "--color-border-strong": { "dark": "derived: oklch(from var(--color-accent) l c h / 0.34)", "light": "oklch(81.39% 0.0250 248.14)", "hex": "light #b6c4d2", "use": "hover / focus border" },
      "--color-accent-soft":   { "derived": "oklch(from var(--color-accent) l c h / 0.08)", "use": "tint fill, selection (both themes)" },
      "--color-accent-border": { "dark": "derived: oklch(from var(--color-accent) l c h / 0.20)", "light": "derived: oklch(from var(--color-accent) l c h / 0.25)", "use": "tinted 1px border" }
    },
    "text": {
      "--color-fg":           { "dark": "oklch(95.94% 0.0200 250.38)", "light": "oklch(21.77% 0.0356 251.29)", "hex": "#e8f3ff / #0d1b2a", "use": "headings / primary" },
      "--color-fg-secondary": { "dark": "oklch(84.95% 0.0376 250.79)", "light": "oklch(31.33% 0.0430 248.12)", "hex": "#bcd0e6 / #1f3346", "use": "body copy" },
      "--color-muted":        { "dark": "oklch(65.82% 0.0450 251.79)", "light": "oklch(50.42% 0.0427 247.48)", "hex": "#7e94ad / #51677c", "use": "meta, caption (AA)" },
      "--color-subtle":       { "dark": "oklch(50.57% 0.0447 251.02)", "light": "oklch(58.43% 0.0356 247.00)", "hex": "#52677e / #6b7e90", "use": "lowest — large/non-text only" }
    },
    "semantic": {
      "--color-success":      { "value": "oklch(89.30% 0.1290 165.92)", "hex": "#7ef7c8", "use": "mint" },
      "--color-warning":      { "value": "oklch(88.03% 0.1348 86.06)",  "hex": "#ffd166", "use": "gold" },
      "--color-danger":       { "value": "oklch(76.13% 0.1420 25.57)",  "hex": "#ff8b82", "use": "coral, legible on navy" },
      "--color-info":         { "value": "oklch(78.57% 0.1153 246.66)", "hex": "#79c0ff", "use": "neutral blue notice" },
      "--color-success-soft": { "derived": "oklch(from var(--color-success) l c h / 0.10)" },
      "--color-warning-soft": { "derived": "oklch(from var(--color-warning) l c h / 0.10)" },
      "--color-danger-soft":  { "derived": "oklch(from var(--color-danger) l c h / 0.10)" },
      "--color-info-soft":    { "derived": "oklch(from var(--color-info) l c h / 0.10)" }
    },
    "hud": {
      "--hud-panel": { "value": "oklch(18.53% 0.0300 257.55 / 0.88)", "use": "frosted navy panel; pair with backdrop blur(10px)" },
      "--hud-line":  { "derived": "oklch(from var(--color-accent) l c h / 0.16)" }
    }
  },
  "typography": {
    "webFontsLink": "https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap",
    "families": {
      "--font-sans":    "'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif",
      "--font-display": "'Space Grotesk', system-ui, sans-serif",
      "--font-mono":    "'JetBrains Mono', 'SF Mono', 'Fira Code', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace"
    },
    "scale": {
      "--text-eyebrow": "0.7rem", "--text-xs": "0.72rem", "--text-sm": "0.82rem", "--text-base-ui": "0.9rem", "--text-base": "1rem",
      "--text-prose": "1.075rem", "--text-lg": "1.15rem", "--text-h3": "1.25rem", "--text-h2": "1.5rem", "--text-h1": "2rem",
      "--text-display": "clamp(1.6rem, 4vw, 2.4rem)", "--text-display-xl": "clamp(2rem, 6vw, 3.5rem)"
    },
    "weight": {
      "--weight-regular": "400", "--weight-medium": "500", "--weight-semibold": "600", "--weight-heading": "650", "--weight-bold": "700"
    },
    "leading": {
      "--leading-tight": "1.1", "--leading-snug": "1.25", "--leading-normal": "1.5", "--leading-relaxed": "1.6", "--leading-prose": "1.8"
    },
    "tracking": {
      "--tracking-tight": "-0.03em", "--tracking-snug": "-0.02em", "--tracking-heading": "-0.01em", "--tracking-caps": "0.08em", "--tracking-caps-wide": "0.16em"
    }
  },
  "spacing": {
    "--space-0": "0", "--space-1": "0.25rem", "--space-2": "0.4rem", "--space-3": "0.6rem", "--space-4": "0.8rem", "--space-5": "1rem",
    "--space-6": "1.2rem", "--space-7": "1.5rem", "--space-8": "1.75rem", "--space-9": "2rem", "--space-10": "2.5rem", "--space-11": "3rem", "--space-12": "4rem",
    "--space-page": "clamp(2rem, 5vw, 3.5rem)"
  },
  "radii": {
    "--radius-xs": "3px", "--radius-sm": "5px", "--radius-md": "6px", "--radius-lg": "8px", "--radius-xl": "10px",
    "--radius-2xl": "12px", "--radius-3xl": "14px", "--radius-pill": "999px", "--radius-full": "50%"
  },
  "elevation": {
    "glows": {
      "$comment": "accent-derived box-shadows; dropped to `none` in the ink/print blocks (box-shadow can't ride light-dark()). --glow-accent-strong is the .btn--glow hover target.",
      "--glow-text":          "0 0 36px oklch(from var(--color-accent) l c h / 0.25)",
      "--glow-avatar":        "0 0 38px -6px oklch(from var(--color-accent) l c h / 0.50)",
      "--glow-accent":        "0 0 24px -6px oklch(from var(--color-accent) l c h / 0.55)",
      "--glow-accent-strong": "0 0 30px -4px oklch(from var(--color-accent) l c h / 0.85)",
      "--glow-gold":          "0 0 28px -8px oklch(from var(--color-accent-2) l c h / 0.40)"
    },
    "shadows": {
      "$comment": "floating chrome only. sm/md/lg soften in ink ([data-theme=light]) and drop in print; multi-layer values can't use light-dark().",
      "--shadow-none": "none",
      "--shadow-sm": "0 1px 3px rgb(0 0 0 / 0.5)",
      "--shadow-md": "0 6px 18px rgb(0 0 0 / 0.5), 0 2px 6px rgb(0 0 0 / 0.4)",
      "--shadow-lg": "0 16px 48px rgb(0 0 0 / 0.55)",
      "--shadow-cockpit": "0 24px 60px -24px rgb(0 0 0 / 0.85)",
      "--shadow-drawer": "0 -14px 36px rgb(0 0 0 / 0.55)"
    },
    "--ring-focus": "0 0 0 2px var(--color-bg), 0 0 0 4px var(--color-accent)"
  },
  "backdrop": {
    "$comment": "the signature .brand-backdrop layers; light-dark(LIGHT, DARK) → transparent in ink, accent tint in dark",
    "--backdrop-glow-cyan": "light-dark(transparent, oklch(from var(--color-accent) l c h / 0.100))",
    "--backdrop-glow-gold": "light-dark(transparent, oklch(from var(--color-accent-2) l c h / 0.050))",
    "--backdrop-grid":      "light-dark(transparent, oklch(from var(--color-accent) l c h / 0.022))",
    "--backdrop-grid-size": "44px"
  },
  "motion": {
    "--ease-standard": "cubic-bezier(0.4, 0, 0.2, 1)",
    "--ease-out": "cubic-bezier(0.2, 0, 0, 1)",
    "--ease-emphasized": "cubic-bezier(0.7, 0, 0.3, 1)",
    "--dur-instant": "0ms", "--dur-fast": "150ms", "--dur-medium": "260ms",
    "--dur-slow": "400ms", "--dur-pulse": "2400ms", "--dur-roll": "11s"
  },
  "zIndex": {
    "--z-base": "0", "--z-raised": "10", "--z-hud": "15", "--z-drawer": "25",
    "--z-tabbar": "30", "--z-overlay": "50", "--z-popover": "60", "--z-toast": "80"
  },
  "breakpoints": {
    "$comment": "for reference in @media — custom props can't be used in queries",
    "--bp-sm": "640px", "--bp-md": "820px", "--bp-lg": "1024px", "--bp-xl": "1280px"
  }
}
